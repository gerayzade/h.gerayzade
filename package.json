    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "prepare": "husky",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "nuxt": "^4.4.2",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
