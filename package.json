  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": "npm run lint"
  },
  "scripts": {
    "dev": "nuxt dev --port 3000",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "lint": "eslint --ext .ts,.vue --ignore-path .gitignore .",
    "lint:fix": "npm run lint -- --fix",
