    "@vueuse/core": "^13.9.0",
    "lodash": "^4.17.21",
    "pinia": "^3.0.4"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@vite-pwa/nuxt": "^0.10.6",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sass": "^1.77.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vue-tsc": "^2.1.10",
    "eslint": "^8.53.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-vue": "^9.20.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
